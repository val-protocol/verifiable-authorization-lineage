# @val-protocol/webhook-receiver — env config

# Required: primary signing secret + its kid (sha256(secret)[0:8]).
# Get both from your VAL operator's webhook-endpoint registration.
VAL_WEBHOOK_SECRET_PRIMARY=whsec_REPLACE_ME_WITH_REAL_64BYTE_SECRET
VAL_WEBHOOK_SECRET_KID_PRIMARY=REPLACE8H

# Optional: secondary signing secret + kid during a rotation grace window.
# When the operator rotates the secret, deliveries arrive dual-signed for the
# grace window. Set both pairs here so the receiver accepts either; remove the
# SECONDARY pair once the grace window expires.
# VAL_WEBHOOK_SECRET_SECONDARY=whsec_OLD_SECRET_DURING_ROTATION
# VAL_WEBHOOK_SECRET_KID_SECONDARY=OLD8HEX

# Replay tolerance window in seconds. Default 300 (5 minutes).
# Tighten for high-security environments; loosen if clients have clock skew.
VAL_WEBHOOK_TOLERANCE_SECONDS=300

# Port to listen on. Default 4321.
PORT=4321
