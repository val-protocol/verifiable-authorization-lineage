{
  "name": "@val-protocol/webhook-receiver",
  "version": "0.1.0",
  "description": "Reference signed-webhook receiver for VAL chain-event deliveries. HMAC-SHA256 timing-safe verification with rotation grace, replay protection, family-prefixed event router, chain-field extraction. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "author": "RIGA <hello@riga.solutions>",
  "homepage": "https://github.com/val-protocol/verifiable-authorization-lineage/tree/main/packages/webhook-receiver",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/val-protocol/verifiable-authorization-lineage.git",
    "directory": "packages/webhook-receiver"
  },
  "bugs": {
    "url": "https://github.com/val-protocol/verifiable-authorization-lineage/issues"
  },
  "keywords": [
    "val",
    "webhook",
    "hmac",
    "receiver",
    "verification",
    "chain",
    "audit"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "bin": {
    "val-webhook-receiver": "./bin/val-webhook-receiver"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "test": "node --test --import tsx test/*.test.ts",
    "start": "tsx src/server.ts",
    "prepublishOnly": "npm run build && npm test && ../../scripts/verify-esm-extensions.sh"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4",
    "typescript": "^5"
  }
}
