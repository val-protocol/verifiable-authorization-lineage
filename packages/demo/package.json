{
  "name": "@val-protocol/demo",
  "version": "0.1.1",
  "description": "Runnable VAL demo: mints a live Profile-B chain (device-key-signed human root, delegated agent actions, a consent bond), verifies it offline, then attacks it four ways — byte tamper, full history rewrite, signature strip, silent truncation — showing exactly what each attack breaks and what it can only demote. Run: npx @val-protocol/demo",
  "license": "Apache-2.0",
  "author": "RIGA <hello@riga.solutions>",
  "type": "module",
  "bin": {
    "val-demo": "./dist/demo.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "val",
    "demo",
    "hash-chain",
    "authorization",
    "verifier",
    "tamper-evident"
  ],
  "homepage": "https://github.com/val-protocol/verifiable-authorization-lineage/tree/main/packages/demo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/val-protocol/verifiable-authorization-lineage.git",
    "directory": "packages/demo"
  },
  "bugs": {
    "url": "https://github.com/val-protocol/verifiable-authorization-lineage/issues"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/demo.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "prepublishOnly": "node ../../scripts/verify-example-ids.mjs && npm run build"
  },
  "dependencies": {
    "@val-protocol/chain-verifier": "^0.11.1",
    "@val-protocol/chain-verifier-cli": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
