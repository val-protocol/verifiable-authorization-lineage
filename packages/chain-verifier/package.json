{
  "name": "@val-protocol/chain-verifier",
  "version": "0.1.0",
  "description": "Reference offline verifier for Verifiable Authorization Lineage (VAL). Zero runtime dependencies \u2014 pure SHA-256 against the canonical preimage specified in the VAL wire format. Verify chain integrity, lineage, and scope client-side without trusting the operator.",
  "license": "Apache-2.0",
  "author": "RIGA <hello@riga.solutions>",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "hash-chain",
    "audit",
    "ndjson",
    "sha256",
    "tamper-evident",
    "verifier",
    "val",
    "verifiable-authorization-lineage"
  ],
  "homepage": "https://github.com/val-protocol/verifiable-authorization-lineage/tree/main/packages/chain-verifier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/val-protocol/verifiable-authorization-lineage.git",
    "directory": "packages/chain-verifier"
  },
  "bugs": {
    "url": "https://github.com/val-protocol/verifiable-authorization-lineage/issues"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build && ../../scripts/verify-esm-extensions.sh"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
